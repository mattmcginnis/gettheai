{
  "name": "getthe-domain-marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "AI-enabled domain marketplace for the GetThe Network.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "db:smoke": "node scripts/db-workflow-smoke.js",
    "infra:up": "docker compose up -d postgres meilisearch",
    "infra:down": "docker compose down",
    "preview:pull": "npx vercel pull --yes --environment=preview",
    "preview:build": "npx vercel build",
    "preview:deploy": "npx vercel deploy --prebuilt"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.12.0",
    "@aws-sdk/client-s3": "^3.940.0",
    "@prisma/client": "^6.8.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
