DATABASE_URL="postgresql://getthe:getthe@localhost:55432/getthe"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"

# Clerk production integration.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
CLERK_DEFAULT_ROLE="buyer"
ALLOW_LOCAL_AUTH_FALLBACK="false"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/buyer"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/account/security"

# Escrow.com launch handoff/API integration.
ESCROW_API_BASE_URL="https://api.escrow.com/2017-09-01"
ESCROW_API_EMAIL=""
ESCROW_API_KEY=""
ESCROW_MODE="handoff"
ESCROW_WEBHOOK_SECRET=""
ESCROW_WEBHOOK_REPLAY_WINDOW_SECONDS="300"

# Transactional email.
POSTMARK_SERVER_TOKEN=""
POSTMARK_FROM_EMAIL="transactions@getthe.com"

# Optional live AI provider. The app ships with a deterministic local appraisal engine.
OPENAI_API_KEY=""
AI_PROVIDER="local"
OPENAI_MODEL="gpt-5-mini"

# Search defaults to Postgres. Set SEARCH_INDEX_PROVIDER to meilisearch or typesense only when
# you intentionally want a managed external search index.
SEARCH_INDEX_PROVIDER="postgres"
MEILISEARCH_HOST=""
MEILISEARCH_API_KEY=""
TYPESENSE_HOST=""
TYPESENSE_API_KEY=""
SEARCH_INDEX_NAME="domain_listings"

# Set to true in production CI to fail when launch secrets are missing.
REQUIRE_PRODUCTION_SECRETS="false"
RATE_LIMIT_WRITES_PER_MINUTE="120"

# S3-compatible storage. R2 can use S3_ENDPOINT and S3_PUBLIC_BASE_URL.
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""
